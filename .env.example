# ===========================
# Google Cloud / Vertex AI
# ===========================
# REQUIRED: replace with your GCP project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Optional (defaults to us-central1)
GOOGLE_CLOUD_LOCATION=us-central1
# REQUIRED for local auth: path to service account json key file
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ===========================
# Qdrant
# ===========================
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=enterprise_kb
QDRANT_TOP_K=5

# ===========================
# VAPI webhook auth
# ===========================
# Optional but recommended: shared secret expected from VAPI headers
# The app checks x-vapi-secret OR Authorization: Bearer <secret>
VAPI_WEBHOOK_SECRET=replace-with-your-vapi-webhook-secret
