# ==============================================================================
# HackBLR - Global Environment Template
# Copy this file to .env and fill in your actual credentials.
# ==============================================================================

# 🎙️ VAPI.AI CONFIGURATION
# ------------------------------------------------------------------------------
# Your Public Key (from Vapi Dashboard > Account)
VITE_VAPI_PUBLIC_KEY=

# Your Assistant ID (from Vapi Dashboard > Assistants)
VITE_VAPI_ASSISTANT_ID=your-vapi-assistant-id

# Your Private Secret Key (Required for the terminal management script)
VAPI_SECRET_KEY=your-vapi-private-key

# ☁️ GOOGLE CLOUD / VERTEX AI
# ------------------------------------------------------------------------------
# Your Google Cloud Project ID (e.g., hackblr-493411)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Preferred GCP Region (e.g., us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# Optional: Path to your service account JSON (only needed for local testing)
# GOOGLE_APPLICATION_CREDENTIALS=./your-service-account.json

# 📂 QDRANT VECTOR DATABASE
# ------------------------------------------------------------------------------
# Local: http://localhost:6333
# Cloud: http://34.31.164.38:6333 (Your GCE VM IP)
QDRANT_URL=http://your-qdrant-ip:6333

# Optional: If you set up an API key for Qdrant
QDRANT_API_KEY= 

# The name of your collection
QDRANT_COLLECTION=enterprise_kb

# 🔗 INTERNAL SERVICE COMMUNICATION
# ------------------------------------------------------------------------------
# The URL of your live Python API (Cloud Run)
PYTHON_API_URL=https://hackblr-python-api-xxxx.a.run.app

# Port for Node.js API (Default: 8080 for Cloud Run)
PORT=8080
NODE_ENV=development
